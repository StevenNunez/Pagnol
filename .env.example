# ============================================================
# PAGNOL — Variables de entorno requeridas
# Copia este archivo a .env.local y completa con tus valores.
# NUNCA subas .env.local ni .env al repositorio.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- Google Gemini AI (Genkit) ---
GEMINI_API_KEY=tu_gemini_api_key_aqui

# --- Email (SMTP para invitaciones y alertas) ---
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USER=tu_correo@tudominio.com
EMAIL_PASS=tu_contraseña_smtp
EMAIL_FROM=hola@teolabs.app
FEEDBACK_ALERT_TO=hola@teolabs.app

# --- URL pública de la app ---
NEXT_PUBLIC_APP_URL=https://tuapp.vercel.app

# --- Cuenta Demo (cuenta Supabase pre-creada con datos de ejemplo) ---
DEMO_EMAIL=demo@pagnol.app
DEMO_PASSWORD=tu_password_demo

# --- Web Push Notifications (VAPID) ---
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key
VAPID_SUBJECT=mailto:admin@tudominio.com
